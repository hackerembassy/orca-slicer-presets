# OrcaSlicer backup
backup.zip

# Filament drafts/copies (not production presets)
filament/Generic TPU @System - Copy.*
filament/Generic TPU matte @annete.*

# Process presets: only validated nozzle sizes are tracked
# Currently only 0.4 is validated
# To add a new nozzle size, remove the corresponding exclusion
# or add negation lines like:
#   !process/*<size>*
#   !process/base/*<size>*
process/*
!process/base/
process/base/*
# Validated nozzle sizes (explicitly included):
# - 0.15 mm (Detail) - validated for PLA
# - 0.3 mm (Standard) - validated for PLA, PETG
# - 0.4 mm (Standard) - fully validated for all materials
# - 0.6 mm (Speed) - validated for PLA, PETG, ABS
#
# Excluded nozzle sizes (pending validation):
# - 0.2 mm, 0.25 mm (Detail) - pending validation
# - 0.5 mm (Standard) - pending validation
# - 0.8 mm, 1.0 mm (Speed) - pending validation
!process/*0.4*
!process/base/*0.4*
!process/*0.15*
!process/base/*0.15*
!process/*0.3*
!process/base/*0.3*
!process/*0.6*
!process/base/*0.6*
